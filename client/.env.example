# ── API ───────────────────────────────────────────────────────────────────────
REACT_APP_API_URL=http://localhost:3001

# ── Google OAuth ──────────────────────────────────────────────────────────────
REACT_APP_GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# ── WebRTC TURN server (optional but recommended for production) ──────────────
# Without TURN, peers behind strict NAT (school/corporate networks) cannot connect.
# Get credentials at https://www.metered.ca/tools/openrelay/ (free tier available)
# or https://www.twilio.com/stun-turn
REACT_APP_TURN_URL=turn:openrelay.metered.ca:80
REACT_APP_TURN_USERNAME=openrelayproject
REACT_APP_TURN_CREDENTIAL=openrelayproject
