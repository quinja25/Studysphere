# ── Database ─────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=studysphere
DB_USER=root
DB_PASSWORD=yourpassword

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong random secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace_with_a_long_random_secret

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3001
CLIENT_URL=http://localhost:3000

# ── AI (OpenAI) ───────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...
# Optional overrides (defaults shown):
# AI_MODEL=gpt-4o-mini
# AI_DAILY_TOKEN_LIMIT=50000
# RAG_EMBEDDING_DIMENSIONS=1536
# RAG_CHUNK_SIZE=300
# RAG_SIMILARITY_THRESHOLD=0.3
# MAX_XP_DEBT=-100

# ── Email (for password reset) ────────────────────────────────────────────────
# Leave blank to skip sending emails (reset links are logged to console in dev)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@email.com
SMTP_PASS=your_app_password
SMTP_FROM=StudySphere <no-reply@studysphere.com>

# ── Google OAuth (server-side verification) ───────────────────────────────────
# Not strictly required — the server only verifies the Google access token
# by calling Google's userinfo endpoint, no client secret needed.

# ── WebRTC TURN server (optional but recommended for production) ──────────────
# Without a TURN server, peers behind symmetric NAT (school/corporate networks)
# may fail to connect. Get free credentials at metered.ca or use Twilio.
# These are read by the REACT_APP_ variables in the client .env
